{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "avatar_url": { "type": "string" }
      }
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post",
      "type": "object",
      "properties": {
        "post_id": { "type": "string" },
        "user_id": { "type": "string" },
        "parent_id": { "type": "string" },
        "content": { "type": "string" },
        "media_url": { "type": "string" },
        "likes_count": { "type": "number" },
        "replies_count": { "type": "number" },
        "is_edited": { "type": "boolean" },
        "is_deleted": { "type": "boolean" },
        "is_pinned": { "type": "boolean" },
        "is_hidden": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["post_id", "user_id", "content"]
    },
    "CommentLike": {
      "title": "Comment Like",
      "description": "A like on a comment",
      "type": "object",
      "properties": {
        "comment_id": { "type": "string" },
        "user_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["comment_id", "user_id"]
    },
    "CommentReport": {
      "title": "Comment Report",
      "description": "A report on a comment",
      "type": "object",
      "properties": {
        "comment_id": { "type": "string" },
        "user_id": { "type": "string" },
        "reason": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["comment_id", "user_id", "reason"]
    },
    "Post": {
      "title": "Post",
      "description": "A post in the community",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "content": { "type": "string" },
        "media_urls": { "type": "array", "items": { "type": "string" } },
        "likes_count": { "type": "number" },
        "comments_count": { "type": "number" },
        "shares_count": { "type": "number" },
        "visibility": { "type": "string", "enum": ["public", "private", "group"] },
        "group_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "content"]
    },
    "Like": {
      "title": "Like",
      "description": "A like on a post or comment",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "entity_id": { "type": "string" },
        "entity_type": { "type": "string", "enum": ["post", "comment"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "entity_id", "entity_type"]
    },
    "Follow": {
      "title": "Follow",
      "description": "A follow relationship",
      "type": "object",
      "properties": {
        "follower_id": { "type": "string" },
        "following_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["follower_id", "following_id"]
    },
    "Message": {
      "title": "Message",
      "description": "A direct or group message",
      "type": "object",
      "properties": {
        "conversation_id": { "type": "string" },
        "sender_id": { "type": "string" },
        "content": { "type": "string" },
        "media_url": { "type": "string" },
        "is_read": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["conversation_id", "sender_id", "content"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A 1-1 or group conversation",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "last_message": { "type": "string" },
        "last_message_at": { "type": "string", "format": "date-time" },
        "is_group": { "type": "boolean" },
        "group_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["participants"]
    },
    "Group": {
      "title": "Group",
      "description": "A community group",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "avatar_url": { "type": "string" },
        "privacy": { "type": "string", "enum": ["public", "private"] },
        "creator_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "creator_id"]
    },
    "Story": {
      "title": "Story",
      "description": "A story in the community",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "media_url": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video"] },
        "expires_at": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "media_url", "expires_at"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "comment", "follow", "message"] },
        "actor_id": { "type": "string" },
        "entity_id": { "type": "string" },
        "content": { "type": "string" },
        "is_read": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "type", "actor_id"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Comments"
    },
    "/likes/{likeId}": {
      "schema": { "$ref": "#/entities/Like" },
      "description": "Likes on posts and comments"
    },
    "/follows/{followId}": {
      "schema": { "$ref": "#/entities/Follow" },
      "description": "Follow relationships"
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Direct and group messages"
    },
    "/conversations/{conversationId}": {
      "schema": { "$ref": "#/entities/Conversation" },
      "description": "Chat conversations"
    },
    "/groups/{groupId}": {
      "schema": { "$ref": "#/entities/Group" },
      "description": "Community groups"
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Community posts"
    },
    "/stories/{storyId}": {
      "schema": { "$ref": "#/entities/Story" },
      "description": "Community stories"
    },
    "/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "User notifications"
    },
    "/comment_likes/{likeId}": {
      "schema": { "$ref": "#/entities/CommentLike" },
      "description": "Likes on comments"
    },
    "/comment_reports/{reportId}": {
      "schema": { "$ref": "#/entities/CommentReport" },
      "description": "Reports on comments"
    }
  }
}
